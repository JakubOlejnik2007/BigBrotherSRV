<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="BigBrotherSRV.MainPage"
    Style="{StaticResource MainPage}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="90"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <BoxView Grid.Row="0">
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#3A171F" Offset="0.0" />
                    <GradientStop Color="#2B1924" Offset="0.5" />
                    <GradientStop Color="#1B1B1B" Offset="1.0" />
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>

        <Label
            Grid.Row="0"
            Text="Big Brother"
            Style="{StaticResource Headline}"
            VerticalOptions="End"
            HorizontalOptions="Start"
            Margin="15,0,0,15" />

        <BoxView 
            Grid.Row="1"
            HeightRequest="1"
            BackgroundColor="#FF658F" />

        <ScrollView Grid.Row="2">
            <Grid Padding="30,20" ColumnSpacing="20" RowSpacing="20">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Card -->
                <Border
                    Grid.Row="0"
                    Grid.Column="0"
                    WidthRequest="150"
                    HeightRequest="120"
                    StrokeThickness="0.5"
                    Stroke="#5d5d5d"
                    BackgroundColor="#282828"
                    Padding="15">

                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>

                    <Border.Shadow>
                        <Shadow
                            Brush="#000000"
                            Offset="0,2"
                            Radius="3"
                            Opacity="0.7" />
                    </Border.Shadow>

                    <Label 
                        Text="Hello"
                        TextColor="White"/>
                </Border>

            </Grid>
            <Button
                    Grid.Row="1"
                    Grid.Column="0"
                    x:Name="CounterBtn"
                    Text="Click me"
                    Clicked="OnCounterClicked" />
        </ScrollView>

    </Grid>
</ContentPage>